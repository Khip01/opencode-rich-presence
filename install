#!/usr/bin/env bash
# install — Install OpenCode Discord Presence plugin
#
# Usage: ./install
#
# This script copies the plugin files to ~/.config/opencode/:
#   - plugins/opencode-dc-too-rich-presence.js  (main plugin)
#   - discord-worker.mjs                        (subprocess worker)
#   - discord-config.json                       (your config, if missing)
#   - restart-discord.sh                        (helper to restart worker)
#
# Also adds the plugin to ~/.config/opencode/opencode.jsonc if not already present.
#
# Requirements:
#   - Node.js 18+ (for the worker subprocess)
#   - Bun (used by OpenCode to install npm packages)
#   - Discord Desktop running

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${HOME}/.config/opencode"
PLUGINS_DIR="${CONFIG_DIR}/plugins"

# Detect package manager (prefer bun since OpenCode uses it)
if command -v bun >/dev/null 2>&1; then
    PKG_MANAGER="bun"
elif command -v npm >/dev/null 2>&1; then
    PKG_MANAGER="npm"
else
    echo "ERROR: Neither bun nor npm found. Please install Node.js 18+ first."
    echo "  https://nodejs.org/"
    exit 1
fi

echo "=== OpenCode Discord Presence Installer ==="
echo ""
echo "Project:  $SCRIPT_DIR"
echo "Target:   $CONFIG_DIR"
echo "PM:       $PKG_MANAGER"
echo ""

# Create directories
mkdir -p "$PLUGINS_DIR"

# Check existing install
echo "--- Checking existing install ---"
EXISTING_PLUGIN=0
EXISTING_WORKER=0
EXISTING_CONFIG=0
[ -f "$PLUGINS_DIR/opencode-dc-too-rich-presence.js" ] && EXISTING_PLUGIN=1
[ -f "$CONFIG_DIR/discord-worker.mjs" ] && EXISTING_WORKER=1
[ -f "$CONFIG_DIR/discord-config.json" ] && EXISTING_CONFIG=1

if [ "$EXISTING_PLUGIN" = "1" ]; then echo "  Plugin file exists (will overwrite)"; fi
if [ "$EXISTING_WORKER" = "1" ]; then echo "  Worker file exists (will overwrite)"; fi
if [ "$EXISTING_CONFIG" = "1" ]; then echo "  Config file exists (will keep your settings)"; fi
echo ""

# Copy plugin file
echo "--- Copying files ---"
cp "$SCRIPT_DIR/opencode-dc-too-rich-presence.js" "$PLUGINS_DIR/opencode-dc-too-rich-presence.js"
echo "  ✓ Plugin → $PLUGINS_DIR/opencode-dc-too-rich-presence.js"

# Copy worker file
cp "$SCRIPT_DIR/discord-worker.mjs" "$CONFIG_DIR/discord-worker.mjs"
chmod +x "$CONFIG_DIR/discord-worker.mjs"
echo "  ✓ Worker → $CONFIG_DIR/discord-worker.mjs"

# Copy restart script (so user can run it from anywhere)
cp "$SCRIPT_DIR/restart-discord.sh" "$CONFIG_DIR/restart-discord.sh"
chmod +x "$CONFIG_DIR/restart-discord.sh"
echo "  ✓ Restart script → $CONFIG_DIR/restart-discord.sh"

# Copy config (only if doesn't exist, to preserve user settings)
if [ "$EXISTING_CONFIG" = "0" ]; then
    cp "$SCRIPT_DIR/config/discord-config.example.json" "$CONFIG_DIR/discord-config.json"
    echo "  ✓ Config → $CONFIG_DIR/discord-config.json (NEW)"
    echo ""
    echo "  ⚠️  Edit $CONFIG_DIR/discord-config.json and set your Discord Application ID!"
    echo "     See SETUP.md for instructions on creating a Discord Application."
else
    echo "  ✓ Config kept (existing): $CONFIG_DIR/discord-config.json"
fi

# Install npm dependency (the plugin needs @xhayper/discord-rpc for the worker)
echo ""
echo "--- Installing npm dependencies ---"
if [ -f "$CONFIG_DIR/package.json" ]; then
    echo "  Updating existing $CONFIG_DIR/package.json"
    cp "$CONFIG_DIR/package.json" "$CONFIG_DIR/package.json.bak" 2>/dev/null || true
fi

# Create/update package.json with deps
cat > "$CONFIG_DIR/package.json.tmp" <<EOF
{
    "type": "module",
    "dependencies": {
        "@opencode-ai/plugin": "$(npm view @opencode-ai/plugin version 2>/dev/null || echo '1.0.0')",
        "@xhayper/discord-rpc": "1.3.4"
    }
}
EOF
mv "$CONFIG_DIR/package.json.tmp" "$CONFIG_DIR/package.json"

cd "$CONFIG_DIR"
if [ "$PKG_MANAGER" = "bun" ]; then
    bun install
else
    npm install
fi

echo "  ✓ Dependencies installed"

# Add plugin to opencode.jsonc
echo ""
echo "--- Updating opencode.jsonc ---"
OPENCODE_JSON="$CONFIG_DIR/opencode.jsonc"
if [ -f "$OPENCODE_JSON" ]; then
    if grep -q "opencode-dc-too-rich-presence" "$OPENCODE_JSON"; then
        echo "  ✓ Plugin already registered in opencode.jsonc"
    else
        # Add plugin to existing config
        # Use sed to insert into the "plugin" array
        if grep -q '"plugin"' "$OPENCODE_JSON"; then
            sed -i 's/"plugin":\s*\[\([^]]*\)\]/"plugin": [\1, "opencode-dc-too-rich-presence"]/' "$OPENCODE_JSON"
            echo "  ✓ Added plugin to existing plugin array"
        else
            # No plugin array, add one
            sed -i '1a\  "plugin": ["opencode-dc-too-rich-presence"],' "$OPENCODE_JSON"
            echo "  ✓ Added plugin array to opencode.jsonc"
        fi
    fi
else
    # Create opencode.jsonc with plugin
    cat > "$OPENCODE_JSON" <<EOF
{
    "plugin": ["opencode-dc-too-rich-presence"]
}
EOF
    echo "  ✓ Created opencode.jsonc with plugin entry"
fi

echo ""
echo "=== Installation Complete! ==="
echo ""
echo "Next steps:"
echo "  1. Edit your config:  $CONFIG_DIR/discord-config.json"
echo "     (set discordAppId to your Discord Application ID)"
echo "  2. Restart OpenCode"
echo ""
echo "After OpenCode is running, you can:"
echo "  - Restart Discord worker:  $CONFIG_DIR/restart-discord.sh"
echo "  - Monitor presence:         watch -n 1 'tail -15 ~/.config/opencode/presence-state.txt'"
echo "  - Uninstall:               ./uninstall"
