{
  "name": "opencode-rich-presence",
  "version": "3.1.8",
  "description": "OpenCode plugin + daemon that pushes AI session state to Discord via a single persistent connection.",
  "type": "module",
  "main": "./src/plugin/index.js",
  "bin": {
    "opencode-rpc": "./bin/opencode-rpc.js"
  },
  "scripts": {
    "test": "node tests/phase1-harness.mjs && node tests/phase2-harness.mjs && node tests/phase2-v2-harness.mjs && node tests/cli-lifecycle.mjs",
    "test:phase1": "node tests/phase1-harness.mjs",
    "test:phase2": "node tests/phase2-harness.mjs",
    "test:phase2-v2": "node tests/phase2-v2-harness.mjs",
    "test:cli-lifecycle": "node tests/cli-lifecycle.mjs",
    "test:pre-release": "node tests/pre-release.mjs",
    "test:post-release": "node tests/post-release.mjs",
    "syntax": "node scripts/syntax-check.js",
    "smoke": "node scripts/smoke-test.js",
    "prepack": "node scripts/check-pkg.js"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "discord",
    "discord-opencode-rpc",
    "discord-rpc",
    "opencode-rpc",
    "ai",
    "llm",
    "cross-platform",
    "cli"
  ],
  "author": {
    "name": "Khip01",
    "url": "https://github.com/Khip01"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Khip01/opencode-rich-presence.git"
  },
  "bugs": {
    "url": "https://github.com/Khip01/opencode-rich-presence/issues"
  },
  "homepage": "https://github.com/Khip01/opencode-rich-presence#readme"
}
